# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5500

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pefa_church
DB_USER=postgres
DB_PASS=postgres
DATABASE_URL=

# Auth
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Site
SITE_NAME=Gwikonge PEFA Church
SITE_EMAIL=info@gwikongepefa.org
TIMEZONE=Africa/Nairobi

# Mail (optional - for notifications/newsletter)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@gwikongepefa.org

# Payments (optional - fill in when ready to go live)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Google Maps (for Contact page)
GMAPS_API_KEY=

# CAPTCHA (hCaptcha recommended; set CAPTCHA_SECRET + site key in frontend)
# Provider: 'hcaptcha' (default) or 'recaptcha'
CAPTCHA_SECRET=
CAPTCHA_PROVIDER=hcaptcha
