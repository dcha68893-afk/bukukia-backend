# ═══════════════════════════════════════════════════════════════════
#  Gwikonge PEFA Church — Backend Environment Variables
#  Copy this file to .env and fill in every value before starting.
# ═══════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development        # change to 'production' on Render

# ── Frontend origin (for CORS) ────────────────────────────────────
# Comma-separated list of allowed origins; leave blank to allow all.
# On Render, set this to the deployed frontend origin:
CLIENT_URL=https://bukuria-frontend.onrender.com

# ── Database ──────────────────────────────────────────────────────
# OPTION A (recommended for Render, Railway, Heroku, Supabase):
#   Set DATABASE_URL and leave the DB_* vars below blank.
DATABASE_URL=

# OPTION B (local development with a local Postgres install):
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pefa_church
DB_USER=postgres
DB_PASS=postgres

# ── Authentication ────────────────────────────────────────────────
# REQUIRED — generate a secure value:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# ── Site info ─────────────────────────────────────────────────────
SITE_NAME=Gwikonge PEFA Church
SITE_EMAIL=info@gwikongepefa.org
TIMEZONE=Africa/Nairobi

# ── Email / SMTP (Nodemailer) ────────────────────────────────────
# Leave blank to disable email sending (in-app notifications still work).
# Gmail example: use an App Password (not your account password).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=no-reply@gwikongepefa.org

# ── CAPTCHA ───────────────────────────────────────────────────────
# Leave blank to skip CAPTCHA verification during development.
# Set CAPTCHA_SECRET from your hCaptcha or reCAPTCHA dashboard.
CAPTCHA_SECRET=
CAPTCHA_PROVIDER=hcaptcha    # or 'recaptcha'

# ── M-Pesa (Daraja API) ───────────────────────────────────────────
# Leave blank until you're ready to go live with real payments.
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://your-backend.onrender.com/api/donations/mpesa-callback
# Set to "production" once you have LIVE (not sandbox) Daraja credentials from Safaricom.
MPESA_ENV=sandbox

# ── PayPal (card payments) ────────────────────────────────────────
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# ── Google Maps (Contact page embed) ─────────────────────────────
GMAPS_API_KEY=
